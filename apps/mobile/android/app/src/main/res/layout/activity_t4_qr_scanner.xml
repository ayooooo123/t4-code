<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/t4_qr_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/t4_qr_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_gravity="center"
        android:background="@drawable/t4_qr_scan_frame"
        android:importantForAccessibility="no" />

    <TextView
        android:id="@+id/t4_qr_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="72dp"
        android:background="#B3000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:text="@string/t4_qr_scan_status"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp" />

    <Button
        android:id="@+id/t4_qr_cancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="48dp"
        android:minWidth="120dp"
        android:minHeight="48dp"
        android:text="@string/t4_qr_scan_cancel" />

</FrameLayout>
